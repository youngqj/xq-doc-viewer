{
  "name": "xq-doc-viewer",
  "version": "0.1.6",
  "description": "A framework-agnostic document viewer SDK supporting PDF, DOCX, PPTX, Excel, CSV, OFD, images, video, audio, text, and markdown.",
  "type": "module",
  "main": "./dist/xq-doc-viewer.cjs",
  "module": "./dist/xq-doc-viewer.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/xq-doc-viewer.js",
      "require": "./dist/xq-doc-viewer.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite serve dev",
    "build": "vite build",
    "build:iife": "vite build --config vite.config.iife.ts",
    "build:all": "pnpm build && pnpm build:iife",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "release": "bash scripts/release.sh",
    "release:minor": "bash scripts/release.sh minor",
    "release:major": "bash scripts/release.sh major"
  },
  "keywords": [
    "document-viewer",
    "pdf",
    "docx",
    "pptx",
    "excel",
    "csv",
    "ofd",
    "image",
    "video",
    "audio",
    "markdown",
    "watermark",
    "preview"
  ],
  "license": "MIT",
  "author": "youngqj",
  "repository": {
    "type": "git",
    "url": "https://github.com/youngqj/xq-doc-viewer.git"
  },
  "homepage": "https://github.com/youngqj/xq-doc-viewer",
  "bugs": {
    "url": "https://github.com/youngqj/xq-doc-viewer/issues"
  },
  "dependencies": {
    "@lapo/asn1js": "^2.1.3",
    "docx-preview": "^0.3.7",
    "exceljs": "^4.4.0",
    "highlight.js": "^11.11.1",
    "js-md5": "^0.8.3",
    "js-sha1": "^0.7.0",
    "jsrsasign": "^11.1.2",
    "jszip": "^3.10.1",
    "marked": "^18.0.0",
    "ofd-xml-parser": "^0.0.6",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "^5.6.205",
    "pptxtojson": "^2.0.0",
    "sm-crypto": "^0.4.0"
  },
  "devDependencies": {
    "@types/papaparse": "^5.5.2",
    "eslint": "^10.2.0",
    "prettier": "^3.8.2",
    "typescript": "~5.7.3",
    "vite": "~6.0.15",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "~3.0.9"
  }
}
